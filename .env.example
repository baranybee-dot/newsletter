# Klaviyo privát API kulcs (teljes hozzáférés)
KLAVIYO_API_KEY=

# A master Klaviyo email sablon ID-ja, amit a kampányokhoz klónozunk
# (a legutóbbi kampányok sablonja: SU9CfB)
KLAVIYO_TEMPLATE_ID=

# Flask session titok
FLASK_SECRET_KEY=

# Belépési védelem (az app megnyitásakor be kell jelentkezni).
# Az APP_PASSWORD megadása KÖTELEZŐ, különben az app zárva marad.
APP_USERNAME=Vates
APP_PASSWORD=
