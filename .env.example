# Klaviyo privát API kulcs (teljes hozzáférés)
KLAVIYO_API_KEY=

# Claude API kulcs (szöveggenerálás és képelemzés)
ANTHROPIC_API_KEY=

# A master Klaviyo email sablon ID-ja, amit a kampányokhoz klónozunk
# (a legutóbbi kampányok sablonja: SU9CfB)
KLAVIYO_TEMPLATE_ID=

# Flask session titok
FLASK_SECRET_KEY=

# Opcionális: fotókönyvtár elérési útja (alapértelmezés: static/photo_library)
PHOTO_LIBRARY_PATH=

# Opcionális: referencia header képek mappája (alapértelmezés: static/reference_headers)
REFERENCE_HEADERS_PATH=
